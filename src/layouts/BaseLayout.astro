---
import '../styles/global.css';
import { getLocaleFromUrl, useTranslations, getLocalizedPath, type Locale } from '../i18n/ui';

interface Props {
  title?: string;
  /** Optional description used in OG meta + title suffix */
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'en' ? 'bn' : 'en';
const selfPath = Astro.url.pathname;
const otherPath = getLocalizedPath(selfPath, otherLocale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const enPath = locale === 'en' ? selfPath : otherPath;
const bnPath = locale === 'bn' ? selfPath : otherPath;

const { title, description } = Astro.props;
const fullTitle = title ? `${title} · ${t('site.title')}` : `${t('site.title')} — ${t('site.tagline')}`;
const desc = description ?? t('site.tagline');

const isHome = selfPath === `${base}/${locale}` || selfPath === `${base}/${locale}/`;

const navItems = [
  { href: `${base}/${locale}/about`,        label: t('nav.about') },
  { href: `${base}/${locale}/publications`, label: t('nav.publications') },
  { href: `${base}/${locale}/books`,        label: t('nav.books') },
  { href: `${base}/${locale}/arboretum`,    label: t('nav.arboretum') },
  { href: `${base}/${locale}/blog`,         label: t('nav.blog') },
  { href: `${base}/${locale}/search`,       label: t('nav.search') },
];
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#F4EFE4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#100E0A" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />

    <link rel="canonical" href={selfPath} />
    <link rel="alternate" hreflang="en" href={enPath} />
    <link rel="alternate" hreflang="bn" href={bnPath} />
    <link rel="alternate" hreflang="x-default" href={enPath} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Noto+Serif+Bengali:wght@400;500;600;700&display=swap"
    />

    <title>{fullTitle}</title>

    <script is:inline define:vars={{ locale }}>
      try {
        document.cookie = 'lang=' + locale + '; path=/; max-age=31536000; SameSite=Lax';
      } catch (e) {}
    </script>
  </head>

  <body>
    <a href="#content" class="skip">{locale === 'bn' ? 'মূল বিষয়বস্তুতে যান' : 'Skip to content'}</a>

    <header class="masthead">
      <div class="container container-wide masthead__inner">
        <a href={`${base}/${locale}`} class="brand" aria-label={t('site.title')}>
          <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
            <path d="M5 27c0-12 6-22 22-22 0 12-6 22-22 22z" />
            <path d="M5 27 27 5" />
            <path d="M11 20 17 14" />
            <path d="M16 20 21 15" />
            <path d="M11 15 16 10" />
          </svg>
          <span class="brand__words">
            <span class="brand__name">{t('site.title')}</span>
            {!isHome && <span class="brand__sub label">{t('site.footer.archive')}</span>}
          </span>
        </a>

        <nav class="nav" aria-label="Primary">
          <ul class="nav__list">
            {navItems.map((it) => {
              const active = selfPath.startsWith(it.href);
              return (
                <li>
                  <a href={it.href} class={active ? 'nav__link is-active' : 'nav__link'}>
                    {it.label}
                  </a>
                </li>
              );
            })}
          </ul>
          <a class="nav__lang" href={otherPath} lang={otherLocale} hreflang={otherLocale}>
            <span aria-hidden="true">⇋</span> {t('toggle.language')}
          </a>
        </nav>
      </div>
    </header>

    <main id="content" data-pagefind-body>
      <slot />
    </main>

    <footer class="colophon">
      <div class="container container-wide colophon__inner">
        <div class="colophon__brand">
          <svg viewBox="0 0 32 32" aria-hidden="true" class="brand__mark brand__mark--small">
            <path d="M5 27c0-12 6-22 22-22 0 12-6 22-22 22z" />
            <path d="M5 27 27 5" />
          </svg>
          <span>&copy; {new Date().getFullYear()} {t('site.title')}</span>
        </div>
        <p class="colophon__note">{t('site.footer.colophon')}</p>
        <a class="colophon__lang" href={otherPath} lang={otherLocale}>{t('toggle.language')}</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .masthead {
    border-bottom: 1px solid var(--rule);
    background: color-mix(in oklab, var(--ground) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .masthead__inner {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    padding-block: var(--s-4);
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    text-decoration: none;
    color: var(--ink);
  }
  .brand:hover { color: var(--moss); }
  .brand__mark {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transform: rotate(-12deg);
    transition: transform var(--dur) var(--ease);
  }
  .brand:hover .brand__mark { transform: rotate(0deg); }
  .brand__mark--small { width: 14px; height: 14px; stroke-width: 1.4; }
  .brand__words {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand__name {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: var(--track-tight);
  }
  :lang(bn) .brand__name { font-size: 1.125rem; font-weight: 500; }
  .brand__sub {
    margin-top: 4px;
    font-size: 0.625rem;
  }

  .nav {
    margin-inline-start: auto;
    display: flex;
    align-items: center;
    gap: var(--s-5);
    flex-wrap: wrap;
  }
  .nav__list {
    display: flex;
    gap: var(--s-5);
    flex-wrap: wrap;
  }
  .nav__link {
    font-size: var(--t-small);
    color: var(--ink-soft);
    text-decoration: none;
    padding: var(--s-1) 0;
    position: relative;
    transition: color var(--dur-fast) var(--ease);
  }
  .nav__link::after {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    inset-inline-end: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur) var(--ease);
  }
  .nav__link:hover, .nav__link.is-active { color: var(--ink); }
  .nav__link:hover::after { transform: scaleX(1); }
  .nav__link.is-active::after {
    transform: scaleX(0.5);
    background: var(--moss);
  }

  .nav__lang {
    font-size: var(--t-mini);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    transition: all var(--dur-fast) var(--ease);
  }
  :lang(bn) .nav__lang { text-transform: none; letter-spacing: 0; font-size: var(--t-small); }
  .nav__lang:hover {
    color: var(--moss);
    border-color: var(--moss);
    background: var(--moss-tint);
  }

  .colophon {
    margin-top: var(--s-9);
    border-top: 1px solid var(--rule);
    padding-block: var(--s-6);
    color: var(--ink-muted);
    font-size: var(--t-small);
  }
  .colophon__inner {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    flex-wrap: wrap;
  }
  .colophon__brand { display: inline-flex; align-items: center; gap: var(--s-2); }
  .colophon__note { flex: 1; min-width: 12rem; font-style: italic; }
  :lang(bn) .colophon__note { font-style: normal; }
  .colophon__lang {
    text-decoration: none;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
  }
  .colophon__lang:hover { color: var(--moss); border-color: var(--moss); }

  @media (max-width: 720px) {
    .masthead__inner { gap: var(--s-3); }
    .nav { gap: var(--s-3); width: 100%; }
    .nav__list { gap: var(--s-4); }
    .brand__name { font-size: 1rem; }
  }
</style>
