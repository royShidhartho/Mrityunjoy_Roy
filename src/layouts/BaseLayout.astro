---
import { getLocaleFromUrl, useTranslations, getLocalizedPath, type Locale } from '../i18n/ui';

interface Props {
  title?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'en' ? 'bn' : 'en';
const switchPath = getLocalizedPath(Astro.url.pathname, otherLocale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const { title = t('site.title') } = Astro.props;
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="alternate" hreflang={otherLocale} href={switchPath} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href={`${base}/${locale}`}>{t('nav.home')}</a>
        <a href={`${base}/${locale}/about`}>{t('nav.about')}</a>
        <a href={`${base}/${locale}/publications`}>{t('nav.publications')}</a>
        <a href={`${base}/${locale}/arboretum`}>{t('nav.arboretum')}</a>
        <a href={`${base}/${locale}/blog`}>{t('nav.blog')}</a>
        <a href={switchPath}>{t('toggle.language')}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()}</p>
    </footer>
  </body>
</html>
