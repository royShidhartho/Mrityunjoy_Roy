---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { languages, useTranslations, type Locale } from '../../../i18n/ui';
import { pick, formatDate } from '../../../utils/content';

export async function getStaticPaths() {
  const pubs = await getCollection('publications');
  const locales = Object.keys(languages);
  return locales.flatMap((locale) =>
    pubs
      .filter((p) => p.data.type === 'blog_post')
      .map((p) => ({
        params: { locale, id: p.id },
        props: { entry: p },
      }))
  );
}

interface Props {
  entry: CollectionEntry<'publications'>;
}

const { entry } = Astro.props;
const locale = Astro.params.locale as Locale;
const otherLocale: Locale = locale === 'bn' ? 'en' : 'bn';
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const p = entry.data;

const title = pick(locale, p.title_bn, p.title_en);
const otherTitle = pick(otherLocale, p.title_bn, p.title_en);
const summary = pick(locale, p.summary_bn, p.summary_en);
const body = pick(locale, p.body_bn, p.body_en);
---

<BaseLayout title={title} description={summary}>
  <article class="post-detail">
    <div class="container">
      <p class="back">
        <a href={`${base}/${locale}/blog`}>{t('blog.back')}</a>
      </p>

      <header class="pd-head">
        <time class="pd-date label">{formatDate(p.date_published, locale)}</time>
        <h1 class="pd-title">{title}</h1>
        {otherTitle && otherTitle !== title && (
          <p class="pd-subtitle" lang={otherLocale}>{otherTitle}</p>
        )}
        {summary && <p class="pd-lede">{summary}</p>}
      </header>

      <hr class="rule rule--ornament" />

      {body && (
        <div class="prose">
          {body.split(/\n\n+/).map((para) => <p>{para}</p>)}
        </div>
      )}

      {p.tags.length > 0 && (
        <footer class="pd-foot">
          <p class="label">{t('publication.tags')}</p>
          <div class="pd-tags">
            {p.tags.map((tag) => (
              <a class="tag" href={`${base}/${locale}/tags/${tag}`}>#{tag}</a>
            ))}
          </div>
        </footer>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .post-detail { padding-block: var(--s-7) var(--s-8); }
  .post-detail > .container { max-width: var(--measure); }

  .back { margin-bottom: var(--s-5); }
  .back a {
    font-size: var(--t-small);
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all var(--dur-fast) var(--ease);
  }
  .back a:hover { color: var(--moss); border-color: currentColor; }

  .pd-head {
    text-align: center;
    margin-bottom: var(--s-5);
  }
  .pd-date {
    display: inline-block;
    margin-bottom: var(--s-3);
    font-variant-numeric: tabular-nums;
  }
  .pd-title {
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    margin-block: var(--s-2) var(--s-3);
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    text-wrap: balance;
  }
  :lang(bn) .pd-title {
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    line-height: 1.2;
  }
  .pd-subtitle {
    font-size: var(--t-lead);
    color: var(--ink-muted);
    font-style: italic;
    margin-bottom: var(--s-4);
  }
  [lang="bn"].pd-subtitle { font-family: var(--font-bn); font-style: normal; }
  [lang="en"].pd-subtitle { font-family: var(--font-en); }
  .pd-lede {
    font-size: var(--t-lead);
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 32rem;
    margin-inline: auto;
  }

  .prose p {
    margin-block: 0 var(--s-4);
    line-height: var(--lh-body);
    color: var(--ink);
  }
  :lang(bn) .prose p { line-height: var(--lh-bn-body); }
  .prose p:first-of-type::first-letter {
    font-size: 3.5em;
    float: left;
    line-height: 0.85;
    padding-inline-end: 0.08em;
    padding-top: 0.05em;
    color: var(--moss);
    font-variation-settings: "opsz" 144, "SOFT" 60;
    font-weight: 400;
  }
  :lang(bn) .prose p:first-of-type::first-letter {
    font-size: 1em;
    float: none;
    color: inherit;
    padding: 0;
  }

  .pd-foot {
    margin-top: var(--s-7);
    padding-top: var(--s-5);
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
    flex-wrap: wrap;
  }
  .pd-tags { display: flex; gap: var(--s-3); flex-wrap: wrap; }
  .tag {
    font-size: var(--t-small);
    color: var(--ink-soft);
    text-decoration: none;
    font-variant: small-caps;
    letter-spacing: 0.04em;
  }
  .tag:hover { color: var(--moss); }
</style>
