---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, useTranslations, type Locale } from '../../i18n/ui';
import { pick } from '../../utils/content';

export async function getStaticPaths() {
  return Object.keys(languages).map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const biography = (await getCollection('biography'))[0];
if (!biography) throw new Error('Biography singleton is missing');
const bio = biography.data;

const longBio = pick(locale, bio.bio_long_bn, bio.bio_long_en);
const heroPhoto = bio.photos[0];
const otherPhotos = bio.photos.slice(1);

const timelineSorted = [...bio.timeline].sort((a, b) => a.year - b.year);
---

<BaseLayout title={t('about.title')}>
  <section class="about-hero">
    <div class="container container-wide">
      <div class="about-hero__grid">
        <div class="about-hero__text">
          <p class="label reveal" data-delay="1">{t('about.title')}</p>
          <h1 class="about-hero__name reveal" data-delay="2">{t('site.title')}</h1>
          <p class="about-hero__short reveal" data-delay="3">
            {pick(locale, bio.bio_short_bn, bio.bio_short_en)}
          </p>
        </div>
        {heroPhoto && (
          <figure class="about-hero__photo reveal" data-delay="3">
            <img src={`${base}/${heroPhoto.src}`}
                 alt={pick(locale, heroPhoto.caption_bn, heroPhoto.caption_en, t('site.title'))}
                 loading="eager" />
            {pick(locale, heroPhoto.caption_bn, heroPhoto.caption_en) && (
              <figcaption>{pick(locale, heroPhoto.caption_bn, heroPhoto.caption_en)}</figcaption>
            )}
          </figure>
        )}
      </div>
    </div>
  </section>

  {longBio && (
    <section class="about-section">
      <div class="container">
        <div class="prose">
          {longBio.split(/\n\n+/).map((para) => <p>{para}</p>)}
        </div>
      </div>
    </section>
  )}

  {timelineSorted.length > 0 && (
    <section class="about-section">
      <div class="container container-wide">
        <header class="section-head">
          <span class="label">{t('about.timeline')}</span>
          <h2 class="section-head__title">{locale === 'bn' ? 'কালপঞ্জি' : 'A working life'}</h2>
        </header>
        <ol class="timeline">
          {timelineSorted.map((ev) => (
            <li class="timeline__row">
              <span class="timeline__year">{ev.year}</span>
              <span class="timeline__dot" aria-hidden="true"></span>
              <p class="timeline__event">{pick(locale, ev.event_bn, ev.event_en)}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  {(bio.affiliations.length > 0 || bio.awards.length > 0) && (
    <section class="about-section">
      <div class="container container-wide">
        <div class="about-grid">
          {bio.affiliations.length > 0 && (
            <div>
              <header class="section-head">
                <span class="label">{t('about.affiliations')}</span>
              </header>
              <ul class="plain-list">
                {bio.affiliations.map((a) => <li>{a}</li>)}
              </ul>
            </div>
          )}

          {bio.awards.length > 0 && (
            <div>
              <header class="section-head">
                <span class="label">{t('about.awards')}</span>
              </header>
              <ul class="plain-list">
                {bio.awards.map((award) => (
                  <li>
                    {award.year && <strong class="award-year">{award.year}</strong>}
                    <span class="award-name">{pick(locale, award.name_bn, award.name_en)}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {otherPhotos.length > 0 && (
    <section class="about-section">
      <div class="container container-wide">
        <header class="section-head">
          <span class="label">{t('about.photos')}</span>
        </header>
        <div class="photo-grid">
          {otherPhotos.map((photo) => (
            <figure>
              <img src={`${base}/${photo.src}`}
                   alt={pick(locale, photo.caption_bn, photo.caption_en, t('site.title'))}
                   loading="lazy" />
              {pick(locale, photo.caption_bn, photo.caption_en) && (
                <figcaption>{pick(locale, photo.caption_bn, photo.caption_en)}</figcaption>
              )}
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  {bio.contact_email && (
    <section class="about-section about-contact">
      <div class="container">
        <header class="section-head">
          <span class="label">{t('about.contact')}</span>
        </header>
        <a class="contact-mail" href={`mailto:${bio.contact_email}`}>{bio.contact_email}</a>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .about-hero {
    padding-block: var(--s-8) var(--s-7);
  }
  .about-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
    align-items: center;
  }
  @media (min-width: 880px) {
    .about-hero__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--s-7);
    }
  }
  .about-hero__name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.025em;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    margin-block: var(--s-3) var(--s-4);
  }
  :lang(bn) .about-hero__name { font-size: clamp(2.25rem, 5.5vw, 4rem); line-height: 1.1; }
  .about-hero__short {
    font-size: var(--t-lead);
    color: var(--ink-soft);
    max-width: 36rem;
    line-height: 1.6;
    font-style: italic;
  }
  :lang(bn) .about-hero__short { font-style: normal; line-height: 1.85; }
  .about-hero__photo {
    margin: 0;
    border-radius: var(--r);
    overflow: hidden;
    border: 1px solid var(--rule);
    box-shadow: 0 24px 60px -32px color-mix(in oklab, var(--ink) 30%, transparent);
  }
  .about-hero__photo img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  .about-hero__photo figcaption {
    padding: var(--s-3);
    font-size: var(--t-small);
    color: var(--ink-muted);
    font-style: italic;
    border-top: 1px solid var(--rule-soft);
  }
  :lang(bn) .about-hero__photo figcaption { font-style: normal; }

  .about-section {
    padding-block: var(--s-7);
    border-top: 1px solid var(--rule);
  }
  .about-section > .container {
    max-width: var(--container-wide);
  }
  .about-section .prose {
    max-width: var(--measure);
    margin-inline: auto;
  }
  .about-section .prose p {
    margin-bottom: var(--s-4);
    line-height: var(--lh-body);
  }
  :lang(bn) .about-section .prose p { line-height: var(--lh-bn-body); }

  .section-head {
    margin-bottom: var(--s-5);
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
    flex-wrap: wrap;
  }
  .section-head__title {
    font-size: var(--t-h3);
    font-weight: 400;
    font-variation-settings: "opsz" 60;
  }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    padding-inline-start: var(--s-4);
    max-width: 48rem;
  }
  .timeline::before {
    content: "";
    position: absolute;
    inset-inline-start: calc(7rem + var(--s-4));
    top: 0.6rem;
    bottom: 0.6rem;
    width: 1px;
    background: var(--rule);
  }
  .timeline__row {
    display: grid;
    grid-template-columns: 7rem 1.25rem 1fr;
    align-items: baseline;
    gap: var(--s-3);
    padding-block: var(--s-3);
  }
  .timeline__year {
    font-variant-numeric: tabular-nums;
    color: var(--ink-muted);
    font-size: var(--t-lead);
    font-variation-settings: "opsz" 24;
  }
  .timeline__dot {
    width: 9px;
    height: 9px;
    border: 1px solid var(--moss);
    background: var(--ground);
    border-radius: 50%;
    justify-self: center;
    position: relative;
    z-index: 1;
  }
  .timeline__event {
    color: var(--ink);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .timeline::before { inset-inline-start: 4rem; }
    .timeline__row { grid-template-columns: 3.5rem 1rem 1fr; }
    .timeline__year { font-size: var(--t-body); }
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }
  @media (min-width: 720px) {
    .about-grid { grid-template-columns: 1fr 1fr; gap: var(--s-7); }
  }

  .plain-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .plain-list li {
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--rule-soft);
  }
  .plain-list li:last-child { border: 0; padding-bottom: 0; }

  .award-year {
    display: inline-block;
    width: 4rem;
    color: var(--moss);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    margin-inline-end: var(--s-3);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--s-4);
  }
  .photo-grid figure { margin: 0; }
  .photo-grid img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: var(--r);
    border: 1px solid var(--rule);
  }
  .photo-grid figcaption {
    margin-top: var(--s-2);
    font-size: var(--t-small);
    color: var(--ink-muted);
    font-style: italic;
  }
  :lang(bn) .photo-grid figcaption { font-style: normal; }

  .about-contact { padding-bottom: var(--s-8); }
  .contact-mail {
    font-size: var(--t-h4);
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: all var(--dur-fast) var(--ease);
  }
  .contact-mail:hover { color: var(--moss); border-color: currentColor; }
</style>
